# ─────────────────────────────────────────────────────────────────────────────
# Amiri POS Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env or .env.production with real secrets to version control.
#
# Vite exposes ONLY variables prefixed with VITE_ to the client code.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API Base URL
# Development (local backend):
VITE_API_BASE_URL=http://localhost:5000/api

# Production (set in .env.production or your hosting dashboard):
# VITE_API_BASE_URL=https://your-backend-url.com/api

# Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
